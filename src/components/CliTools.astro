---
const toolRepos = [
  "https://github.com/laypatel13/data-visualizer",
  "https://github.com/laypatel13/sales-report",
  "https://github.com/laypatel13/grade-analyzer",
  "https://github.com/laypatel13/csv-analyzer",
  "https://github.com/laypatel13/animal-shelter",
  "https://github.com/laypatel13/library-manager",
  "https://github.com/laypatel13/expense-tracker",
];
---

<section id="cli-tools" class="cli-tools">
  <p class="cli-line">
    7 small CLI tools published on PyPI, from back when I was first learning
    Python.<br>
    <a
      id="random-tool-link"
      href={toolRepos[0]}
      target="_blank"
      rel="noopener noreferrer"
    >
      explore a random one
    </a>
  </p>
</section>

<script define:vars={{ toolRepos }}>
  const link = document.getElementById("random-tool-link");
  link?.addEventListener("click", (event) => {
    event.preventDefault();
    const pick = toolRepos[Math.floor(Math.random() * toolRepos.length)];
    window.open(pick, "_blank", "noopener,noreferrer");
  });
</script>

<style>
  .cli-tools {
    margin: 0 0 48px;
  }

  .cli-line {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--text-secondary);
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    margin: 0;
  }

  .cli-line a {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
  }

  .cli-line a:hover,
  .cli-line a:focus-visible {
    color: var(--text-secondary);
  }
</style>