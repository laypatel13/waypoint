---
type Project = {
  name: string;
  description: string;
  tags: string[];
  demo: string | null;
  github: string | null;
  // Path to a local screenshot, relative to /public. Drop the file in
  // e.g. /public/thumbnails/clutch.png and set thumbnail: "/thumbnails/clutch.png".
  // Leave null to fall back to the initial-letter placeholder.
  thumbnail: string | null;
};

const projects: Project[] = [
  {
    name: "clutch",
    description: "Open-source dev activity dashboard — CLI, contribution heatmaps, and PR tooling. Built as project admin for ECSoC26.",
    tags: ["FastAPI", "React", "TypeScript"],
    demo: null,
    github: "https://github.com/laypatel13/clutch",
    thumbnail: "/thumbnails/clutch.png",
  },
  {
    name: "datawash",
    description: "CSV cleaning web app — upload a messy CSV, clean it, and export the result.",
    tags: ["Flask", "Pandas", "Plotly"],
    demo: "https://data-wash-sr98.onrender.com",
    github: null,
    thumbnail: "/thumbnails/datawash.png",
  },
  {
    name: "siloed",
    description: "Multi-tenant RAG app with workspace-level isolation, built as a technical assessment.",
    tags: ["FastAPI", "pgvector", "Groq"],
    demo: "https://siloed-eta.vercel.app/",
    github: "https://github.com/laypatel13/siloed",
    thumbnail: "/thumbnails/siloed.png",
  },
];
---

<section id="work" class="work">
  <p class="section-label">work</p>
  <div class="list">
    {
      projects.map((project) => {
        const imageHref = project.demo ?? project.github;
        const titleHref = project.github ?? project.demo;

        return (
          <article class="project">
            <a
              class="thumb"
              href={imageHref}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Open ${project.name} live demo`}
            >
              {project.thumbnail ? (
                <img class="thumb-img" src={project.thumbnail} alt={`${project.name} preview`} loading="lazy" />
              ) : (
                <span class="thumb-initial">{project.name[0]}</span>
              )}
            </a>

            <div class="details">
              <h3 class="project-title">
                <a href={titleHref} target="_blank" rel="noopener noreferrer">
                  {project.name}
                  <span class="arrow">↗</span>
                </a>
              </h3>
              <p class="project-desc">{project.description}</p>
              <div class="tags">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</section>

<style>
  .work {
    margin: 48px 0;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .project {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .thumb {
    flex-shrink: 0;
    width: 160px;
    aspect-ratio: 2 / 1;
    border-radius: 10px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  .thumb:hover,
  .thumb:focus-visible {
    border-color: var(--text-muted);
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-initial {
    font-family: var(--font-display);
    font-size: 26px;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .details {
    flex: 1;
    min-width: 0;
  }

  .project-title {
    font-size: 16px;
    margin: 0 0 6px;
  }

  .project-title a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    text-decoration: none;
    color: var(--text);
  }

  .project-title a:hover .arrow,
  .project-title a:focus-visible .arrow {
    transform: translate(2px, -2px);
  }

  .arrow {
    display: inline-block;
    font-size: 13px;
    color: var(--text-secondary);
    transition: transform 0.15s ease;
  }

  .project-desc {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0 0 12px;
    line-height: 1.55;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-secondary);
    background: var(--surface);
    border: 0.5px solid var(--border);
    padding: 4px 10px;
    border-radius: 999px;
  }

  @media (max-width: 480px) {
    .project {
      flex-direction: column;
    }

    .thumb {
      width: 100%;
      aspect-ratio: 2 / 1;
    }
  }
</style>
