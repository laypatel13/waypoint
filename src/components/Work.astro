---
type Project = {
  name: string;
  description: string;
  tags: string[];
  demo: string | null;
  github: string | null;
  icon: "cog" | "droplet" | "stack";
};

const projects: Project[] = [
  {
    name: "clutch",
    description: "Open-source dev activity dashboard — CLI, contribution heatmaps, and PR tooling. Built as project admin for ECSoC26.",
    tags: ["FastAPI", "React", "TypeScript"],
    demo: null,
    github: "https://github.com/laypatel13/clutch",
    icon: "cog",
  },
  {
    name: "datawash",
    description: "CSV cleaning web app — upload a messy CSV, clean it, and export the result.",
    tags: ["Flask", "Pandas", "Plotly"],
    demo: "https://data-wash-sr98.onrender.com",
    github: null,
    icon: "droplet",
  },
  {
    name: "siloed",
    description: "Multi-tenant RAG app with workspace-level isolation, built as a technical assessment.",
    tags: ["FastAPI", "pgvector", "Groq"],
    demo: "https://siloed-eta.vercel.app/",
    github: "https://github.com/laypatel13/siloed",
    icon: "stack",
  },
];

const teeth = Array.from({ length: 8 }, (_, i) => i * 45);
---

<section id="work" class="work">
  <p class="section-label">work</p>
  <div class="list">
    {
      projects.map((project) => {
        const imageHref = project.demo ?? project.github;
        const titleHref = project.github ?? project.demo;

        return (
          <article class="project">
            <a
              class="thumb"
              href={imageHref}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Open ${project.name}`}
            >
              {project.icon === "cog" && (
                <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
                  <circle cx="22" cy="22" r="9" stroke="currentColor" stroke-width="2" />
                  <circle cx="22" cy="22" r="3.5" stroke="currentColor" stroke-width="2" />
                  {teeth.map((angle) => (
                    <rect
                      x="20.5"
                      y="6"
                      width="3"
                      height="7"
                      rx="1"
                      stroke="currentColor"
                      stroke-width="1.5"
                      transform={`rotate(${angle} 22 22)`}
                    />
                  ))}
                </svg>
              )}

              {project.icon === "droplet" && (
                <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
                  <path
                    d="M22 6 C22 6 12 20 12 27 A10 10 0 0 0 32 27 C32 20 22 6 22 6 Z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linejoin="round"
                  />
                </svg>
              )}

              {project.icon === "stack" && (
                <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
                  <rect x="8" y="8" width="28" height="7" rx="1.5" stroke="currentColor" stroke-width="2" />
                  <rect x="8" y="18.5" width="28" height="7" rx="1.5" stroke="currentColor" stroke-width="2" />
                  <rect x="8" y="29" width="28" height="7" rx="1.5" stroke="currentColor" stroke-width="2" />
                </svg>
              )}
            </a>

            <div class="details">
              <h3 class="project-title">
                <a href={titleHref} target="_blank" rel="noopener noreferrer">
                  {project.name}
                  <span class="arrow">↗</span>
                </a>
              </h3>
              <p class="project-desc">{project.description}</p>
              <div class="tags">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</section>

<style>
  .work {
    margin: 48px 0;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .project {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .thumb {
    flex-shrink: 0;
    width: 120px;
    height: 80px;
    border-radius: 10px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--text-muted);
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .thumb:hover,
  .thumb:focus-visible {
    border-color: var(--text-muted);
    color: var(--text);
  }

  .details {
    flex: 1;
    min-width: 0;
  }

  .project-title {
    font-size: 16px;
    margin: 0 0 6px;
  }

  .project-title a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    text-decoration: none;
    color: var(--text);
  }

  .project-title a:hover .arrow,
  .project-title a:focus-visible .arrow {
    transform: translate(2px, -2px);
  }

  .arrow {
    display: inline-block;
    font-size: 13px;
    color: var(--text-secondary);
    transition: transform 0.15s ease;
  }

  .project-desc {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0 0 12px;
    line-height: 1.55;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-secondary);
    background: var(--surface);
    border: 0.5px solid var(--border);
    padding: 4px 10px;
    border-radius: 999px;
  }

  @media (max-width: 480px) {
    .project {
      flex-direction: column;
    }

    .thumb {
      width: 100%;
      height: 96px;
    }
  }
</style>
